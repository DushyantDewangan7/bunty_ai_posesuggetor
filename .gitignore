# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local

# typescript
*.tsbuildinfo

# generated native folders
/ios

# Android — track sources, ignore build artifacts and machine-specific files
android/build/
android/.gradle/
android/.cxx/
android/.idea/
android/local.properties
android/**/build/
android/**/.cxx/
android/**/.gradle/
android/captures/
android/*.iml
android/**/*.iml

# JVM/HotSpot crash dumps (root and android/)
hs_err_pid*.log
replay_pid*.log

# Local build caches (kept on D:\ to spare C:)
/.cache/
/.tmp/
/.gradle-user/
/build.log
/metro.log
/build-output*.log
/full-build.log

# Local debug artifacts
/phase1-launch-failure.png

# tooling/agent state
/.claude/
/memory/

# Phase 3A pose pipeline: keep manifest + generated data, ignore raw inputs
/images/source/*
!/images/source/.gitkeep
/images/rejected.txt
