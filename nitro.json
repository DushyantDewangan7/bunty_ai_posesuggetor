{
  "$schema": "https://nitro.margelo.com/nitro.schema.json",
  "cxxNamespace": ["aiposesuggestor", "poseplugin"],
  "ios": {
    "iosModuleName": "AIPoseSuggestorPosePlugin"
  },
  "android": {
    "androidNamespace": ["aiposesuggestor", "poseplugin"],
    "androidCxxLibName": "AIPoseSuggestorPosePlugin"
  },
  "autolinking": {
    "PoseLandmarker": {
      "ios": {
        "language": "swift",
        "implementationClassName": "HybridPoseLandmarker"
      },
      "android": {
        "language": "kotlin",
        "implementationClassName": "HybridPoseLandmarker"
      }
    },
    "PoseLandmarkerOutput": {
      "ios": {
        "language": "swift",
        "implementationClassName": "HybridPoseLandmarkerOutput"
      },
      "android": {
        "language": "kotlin",
        "implementationClassName": "HybridPoseLandmarkerOutput"
      }
    },
    "FaceLandmarkerOutput": {
      "ios": {
        "language": "swift",
        "implementationClassName": "HybridFaceLandmarkerOutput"
      },
      "android": {
        "language": "kotlin",
        "implementationClassName": "HybridFaceLandmarkerOutput"
      }
    }
  },
  "ignorePaths": ["**/node_modules", "**/.cache", "**/android/build", "**/ios/build"]
}
