    "eslint": "9.39.4",
    "eslint-config-expo": "10.0.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "nitrogen": "0.35.6",
    "potrace": "2.1.8",
    "prettier": "3.8.3",
    "puppeteer": "24.5.0",
    "sharp": "0.32.6",
    "typescript": "5.9.3"
